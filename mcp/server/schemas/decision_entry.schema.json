{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionEntry",
  "description": "A decision recorded via the workspace-brain MCP server",
  "type": "object",
  "required": ["decision"],
  "properties": {
    "decision":   { "type": "string" },
    "reason":     { "type": "string" },
    "tags":       { "type": "string" },
    "decided_at": { "type": "string", "format": "date-time" }
  }
}
