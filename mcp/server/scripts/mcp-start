#!/bin/sh
# Start the workspace-brain MCP server in the foreground (stdio mode).
# MCP clients (Claude, Codex) start it automatically as a subprocess.
# Use this script only for manual testing.
set -eu
MCP_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
SERVER="$MCP_ROOT/server/main.py"
exec uv run --with "mcp>=1.0.0" python3 "$SERVER"
