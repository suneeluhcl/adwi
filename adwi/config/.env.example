# Adwi — Environment Variable Template
# Copy this file to config/.env and fill in real values.
# config/.env is gitignored. This file is safe to commit.
#
# MACHINE-LOCAL: these values are specific to your machine and must be
# set up manually on each new clone. They are NEVER committed to git.
#
# Usage: cp config/.env.example config/.env && $EDITOR config/.env

# ── Local API Security ───────────────────────────────────────────────────────
# Shared secret for Safe Command API (:5055) and Obsidian Bridge (:5056).
# When set, all callers (n8n, Open WebUI tools, adwi-sandbox) must present:
#   X-Adwi-Secret: <value>
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# After adding: restart the Safe Command API server, re-import n8n workflows,
# and run: docker compose up -d   (to restart n8n and open-webui with the secret)
ADWI_LOCAL_SECRET=REPLACE_ME

# ── Search APIs ──────────────────────────────────────────────────────────────
# Tavily AI search (https://tavily.com — free tier available)
TAVILY_API_KEY=tvly-REPLACE_ME

# Exa neural search (https://exa.ai — free tier available)
EXA_API_KEY=exa-REPLACE_ME

# Brave Search API (optional independent web index)
BRAVE_SEARCH_API_KEY=REPLACE_ME

# Firecrawl web scraper (https://firecrawl.dev — free tier available)
FIRECRAWL_API_KEY=fc-REPLACE_ME

# Jina Reader fallback page extraction (optional)
JINA_API_KEY=REPLACE_ME

# ── Home Assistant ────────────────────────────────────────────────────────────
# Long-lived access token from HA Profile → Security → Long-Lived Access Tokens
HOME_ASSISTANT_TOKEN=REPLACE_ME
# URL of your Home Assistant instance (local or Tailscale)
HOME_ASSISTANT_URL=http://localhost:8123

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Cloudflare Tunnel token (for external HTTPS access via n8n webhooks)
# Get from: Cloudflare Zero Trust → Access → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for Grafana dashboard (http://localhost:4000)
# MUST be set — compose has no safe fallback.
GRAFANA_PASSWORD=REPLACE_ME

# ── Networking / Remote Access ────────────────────────────────────────────────
# Your machine's Tailscale IP (shown by: tailscale ip -4)
# Used for remote status display in the Adwi REPL.
TAILSCALE_IP=REPLACE_ME

# Obsidian Bridge URL — override only if running on a non-default port.
# Default is http://127.0.0.1:5056 — leave commented unless you changed it.
# OBSIDIAN_BRIDGE_URL=http://127.0.0.1:5056

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Override only if SearXNG runs on a non-default port.
# Default is http://127.0.0.1:8888 — leave commented unless you changed it.
# SEARXNG_URL=http://127.0.0.1:8888

# ── Model routing (non-secret defaults — can be overridden here) ─────────────
# These are already set in adwi/model-routing.env but can be overridden here.
# ADWI_CHAT_BACKEND=local         # "local" or "cloud"
# ADWI_LOCAL_MODEL=adwi:latest
# ADWI_CLOUD_MODEL=models/gemini-2.5-flash

# ── Optional: Gmail OAuth ─────────────────────────────────────────────────────
# Gmail OAuth credentials live in secrets/gmail-credentials.json (gitignored).
# Run: adwi → /gmail-auth   to create this token on a new machine.
# GMAIL_CREDENTIALS_PATH=secrets/gmail-credentials.json

# ── Optional: n8n webhook auth ────────────────────────────────────────────────
# If you set n8n webhook auth, put the shared secret here.
# N8N_WEBHOOK_SECRET=REPLACE_ME
