#!/bin/sh
# Show workspace-brain MCP status.
set -eu
# Resolve symlinks to get the real directory of this script
TARGET="$0"
while [ -L "$TARGET" ]; do
    DIR="$(dirname "$TARGET")"
    TARGET="$(readlink "$TARGET")"
    case "$TARGET" in
        /*) ;;
        *) TARGET="$DIR/$TARGET" ;;
    esac
done
MCP_ROOT="$(cd "$(dirname "$TARGET")/../.." && pwd)"
STATE="$MCP_ROOT/server/state/mcp_state.json"
INDEX_META="$MCP_ROOT/server/state/last_index.json"
DB="$MCP_ROOT/server/storage/memory_index.db"
LOG="$MCP_ROOT/server/logs/mcp_server.log"

echo "=== workspace-brain MCP Status ==="

# Running processes
PIDS="$(pgrep -f 'mcp/server/main.py' 2>/dev/null | tr '\n' ' ')"
if [ -n "$PIDS" ]; then
    echo "Server processes: RUNNING (PIDs: $PIDS)"
else
    echo "Server processes: not running (clients start on demand)"
fi

# State file
if [ -f "$STATE" ]; then
    echo "State file: $STATE"
    python3 -c "import json,sys; d=json.load(open(sys.argv[1])); [print(f'  {k}: {v}') for k,v in d.items()]" "$STATE" 2>/dev/null || cat "$STATE"
else
    echo "State file: not found"
fi

# Index
if [ -f "$DB" ]; then
    COUNT="$(python3 -c "import sqlite3; c=sqlite3.connect('$DB'); print(c.execute('SELECT COUNT(*) FROM entries').fetchone()[0])" 2>/dev/null || echo '?')"
    echo "Index: $DB ($COUNT entries)"
else
    echo "Index: not built yet"
fi

# Last index metadata
if [ -f "$INDEX_META" ]; then
    echo "Last reindex:"
    python3 -c "import json; d=json.load(open('$INDEX_META')); print(f'  {d.get(\"indexed_at\",\"?\")}, {d.get(\"total_entries\",\"?\")} entries')" 2>/dev/null || cat "$INDEX_META"
fi

# Log tail
if [ -f "$LOG" ]; then
    echo "Last 5 log lines:"
    tail -5 "$LOG" | sed 's/^/  /'
fi
