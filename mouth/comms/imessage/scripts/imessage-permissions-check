#!/usr/bin/env python3
"""Check iMessage permissions and system readiness."""
import sys
import os
import sqlite3
import pathlib
import subprocess

ROOT = pathlib.Path.home() / "SuneelWorkSpace"
DB = pathlib.Path.home() / "Library/Messages/chat.db"


def check(label, result, detail=""):
    icon = "OK" if result else "FAIL"
    line = f"  [{icon}] {label}"
    if detail:
        line += f" — {detail}"
    print(line)
    return result


def main():
    print("iMessage Permissions Check")
    print("=" * 40)
    all_ok = True

    # 1. DB exists
    ok = DB.exists()
    check("chat.db exists", ok, str(DB) if ok else f"not found at {DB}")
    all_ok = all_ok and ok

    # 2. Full Disk Access — try reading DB
    fda_ok = False
    if DB.exists():
        try:
            conn = sqlite3.connect(str(DB))
            c = conn.cursor()
            c.execute("SELECT count(*) FROM message LIMIT 1")
            fda_ok = True
            conn.close()
        except Exception as e:
            check("Full Disk Access (chat.db readable)", False, str(e))
            all_ok = False
    if fda_ok:
        check("Full Disk Access (chat.db readable)", True, "FDA is granted")
    elif DB.exists():
        pass  # already printed fail

    # 3. osascript available (for sending)
    osa = subprocess.run(["which", "osascript"], capture_output=True, text=True)
    osa_ok = osa.returncode == 0
    check("osascript available", osa_ok, osa.stdout.strip() if osa_ok else "not found")
    all_ok = all_ok and osa_ok

    # 4. Test Automation permission (dry-run — only checks if Messages is listed, not if allowed)
    print()
    print("  [NOTE] Automation permission for Messages.app cannot be auto-detected.")
    print("         If sending fails, open:")
    print("         System Settings → Privacy & Security → Automation")
    print("         and grant Terminal (or iTerm2/VS Code) access to Messages.")

    # 5. Check plugin install status
    plugin_inv = ROOT / "comms/config/plugin_inventory.json"
    if plugin_inv.exists():
        import json
        try:
            inv = json.loads(plugin_inv.read_text())
            status = inv.get("imessage_plugin", {}).get("status", "unknown")
            check("iMessage Claude plugin", status == "installed",
                  f"status: {status} — run: claude plugin install imessage@claude-plugins-official")
        except Exception:
            pass

    print()
    if all_ok:
        print("Status: READY — iMessage read/send should work.")
    else:
        print("Status: NOT READY — fix the FAIL items above.")
    print()
    print("Docs: ~/SuneelWorkSpace/comms/docs/PERMISSIONS.md")
    return 0 if all_ok else 1


if __name__ == "__main__":
    sys.exit(main())
