#!/usr/bin/env python3
"""Search iMessages in chat.db.

Usage:
  imessage-search <query> [--limit N] [--days D] [--json]
"""
import sys
import sqlite3
import json
import pathlib
import argparse
from datetime import datetime, timedelta

DB = pathlib.Path.home() / "Library/Messages/chat.db"
APPLE_EPOCH_OFFSET = 978307200


def format_ts(apple_ts):
    if not apple_ts:
        return "unknown"
    unix_ts = int(apple_ts) / 1_000_000_000 + APPLE_EPOCH_OFFSET
    return datetime.fromtimestamp(unix_ts).strftime("%Y-%m-%d %H:%M")


def search_messages(query, limit=50, days=30):
    conn = sqlite3.connect(str(DB))
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    cutoff_apple = (int((datetime.now() - timedelta(days=days)).timestamp()) - APPLE_EPOCH_OFFSET) * 1_000_000_000
    c.execute("""
        SELECT
            m.rowid,
            m.text,
            m.is_from_me,
            m.date,
            m.is_read,
            h.id AS handle_id,
            chat.display_name,
            chat.chat_identifier
        FROM message m
        LEFT JOIN handle h ON m.handle_id = h.rowid
        LEFT JOIN chat_message_join cmj ON cmj.message_id = m.rowid
        LEFT JOIN chat ON chat.rowid = cmj.chat_id
        WHERE m.date > ? AND m.text LIKE ? AND m.text IS NOT NULL
        ORDER BY m.date DESC
        LIMIT ?
    """, (cutoff_apple, f"%{query}%", limit))
    rows = [dict(r) for r in c.fetchall()]
    conn.close()
    return rows


def redact_handle(h):
    if not h:
        return "unknown"
    if "@" in h:
        parts = h.split("@")
        return parts[0][:4] + "***@" + parts[1]
    h = h.replace("+", "").replace("-", "").replace(" ", "")
    return h[:4] + "****" + h[-2:] if len(h) > 6 else "****"


def main():
    parser = argparse.ArgumentParser(description="Search iMessages")
    parser.add_argument("query", help="Search text")
    parser.add_argument("--limit", type=int, default=50)
    parser.add_argument("--days", type=int, default=30)
    parser.add_argument("--json", action="store_true", dest="json_out")
    parser.add_argument("--full", action="store_true", help="Show unredacted handles")
    args = parser.parse_args()

    if not DB.exists():
        print("[ERROR] chat.db not found.", file=sys.stderr)
        sys.exit(1)

    try:
        rows = search_messages(args.query, args.limit, args.days)
    except Exception as e:
        print(f"[ERROR] Cannot search chat.db: {e}", file=sys.stderr)
        sys.exit(1)

    if args.json_out:
        out = []
        for r in rows:
            out.append({
                "id": r["rowid"],
                "from_me": bool(r["is_from_me"]),
                "handle": r["handle_id"] if args.full else redact_handle(r["handle_id"]),
                "text_preview": (r["text"] or "")[:200],
                "timestamp": format_ts(r["date"]),
            })
        print(json.dumps(out, indent=2))
        return

    if not rows:
        print(f"No messages matching '{args.query}' in the last {args.days} days.")
        return

    print(f"Search results for '{args.query}' (last {args.days} days, {len(rows)} found)")
    print("=" * 60)
    for r in rows:
        direction = "→ ME" if r["is_from_me"] else "FROM"
        handle = r["handle_id"] if args.full else redact_handle(r["handle_id"])
        ts = format_ts(r["date"])
        text = (r["text"] or "").replace("\n", " ").strip()
        # Highlight the query term
        text_display = text[:200]
        print(f"  [{ts}] {direction} {handle}")
        print(f"    {text_display}")
        print()


if __name__ == "__main__":
    main()
