#!/usr/bin/env python3
"""Send a confirmed email draft (stub — Mail.app not installed)."""
import sys, pathlib

MAIL_APP = pathlib.Path("/Applications/Mail.app")

def main():
    if not MAIL_APP.exists():
        print("[mail-send-confirmed] DISABLED — Mail.app not installed.")
        return 1
    print("[mail-send-confirmed] Mail.app present but send not yet implemented.")
    return 1

if __name__ == "__main__":
    sys.exit(main())
