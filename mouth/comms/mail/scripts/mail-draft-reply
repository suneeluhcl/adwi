#!/usr/bin/env python3
"""Draft an email reply (stub — Mail.app not installed)."""
import sys, pathlib

MAIL_APP = pathlib.Path("/Applications/Mail.app")

def main():
    if not MAIL_APP.exists():
        print("[mail-draft-reply] DISABLED — Mail.app not installed.")
        print("See: ~/SuneelWorkSpace/comms/reports/plugin_recommendations.md")
        return 1
    print("[mail-draft-reply] Mail.app present but draft-reply not yet implemented.")
    return 1

if __name__ == "__main__":
    sys.exit(main())
