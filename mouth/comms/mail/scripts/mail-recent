#!/usr/bin/env python3
"""Show recent emails (stub — Mail.app not installed)."""
import sys, pathlib

MAIL_APP = pathlib.Path("/Applications/Mail.app")

def main():
    if not MAIL_APP.exists():
        print("[mail-recent] DISABLED — Mail.app not installed.")
        print()
        print("To use email features, either:")
        print("  1. Install Apple Mail.app and configure your email account")
        print("  2. Use Gmail via claude plugin (see comms/reports/plugin_recommendations.md)")
        return 1
    import subprocess
    script = """
    tell application "Mail"
        set msgs to messages of inbox of first account
        set result to ""
        repeat with i from 1 to (count of msgs) - 1
            if i > 10 then exit repeat
            set m to item i of msgs
            set result to result & (subject of m) & " | " & (sender of m) & "\n"
        end repeat
        return result
    end tell
    """
    r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=30)
    if r.returncode == 0:
        print(r.stdout.strip())
    else:
        print("Error reading mail:", r.stderr.strip())
        return 1

if __name__ == "__main__":
    sys.exit(main())
