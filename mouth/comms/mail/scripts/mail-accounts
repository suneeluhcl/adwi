#!/usr/bin/env python3
"""List Mail.app accounts (stub — Mail.app not installed)."""
import sys
import pathlib

MAIL_APP = pathlib.Path("/Applications/Mail.app")

def main():
    if not MAIL_APP.exists():
        print("[mail-accounts] Mail.app is not installed.")
        print("See: ~/SuneelWorkSpace/comms/reports/plugin_recommendations.md")
        return 1
    import subprocess
    script = 'tell application "Mail" to get every account'
    result = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=15)
    if result.returncode == 0:
        print("Mail accounts:", result.stdout.strip())
    else:
        print("Error:", result.stderr.strip())
        return 1

if __name__ == "__main__":
    sys.exit(main())
