#!/bin/sh
# Attempt safe automatic repair of MCP subsystem issues.
set -eu
# Resolve symlinks to get the real directory of this script
TARGET="$0"
while [ -L "$TARGET" ]; do
    DIR="$(dirname "$TARGET")"
    TARGET="$(readlink "$TARGET")"
    case "$TARGET" in
        /*) ;;
        *) TARGET="$DIR/$TARGET" ;;
    esac
done
MCP_ROOT="$(cd "$(dirname "$TARGET")/../.." && pwd)"
DB="$MCP_ROOT/server/storage/memory_index.db"
STATE="$MCP_ROOT/server/state/mcp_state.json"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
CODEX_CONFIG="$HOME/.codex/config.toml"

echo "=== workspace-brain MCP Repair ==="

# 1. Ensure directories exist
mkdir -p "$MCP_ROOT/server/storage" "$MCP_ROOT/server/logs" "$MCP_ROOT/server/state" "$MCP_ROOT/server/cache"
echo "[OK] Directories ensured"

# 2. Rebuild index if missing or empty
if [ ! -f "$DB" ]; then
    echo "Index missing — rebuilding..."
    "$MCP_ROOT/server/scripts/mcp-reindex"
else
    COUNT="$(python3 -c "import sqlite3; c=sqlite3.connect('$DB'); print(c.execute('SELECT COUNT(*) FROM entries').fetchone()[0])" 2>/dev/null || echo 0)"
    if [ "${COUNT:-0}" -eq 0 ] 2>/dev/null; then
        echo "Index empty — rebuilding..."
        "$MCP_ROOT/server/scripts/mcp-reindex"
    else
        echo "[OK] Index has $COUNT entries"
    fi
fi

# 3. Re-register with Claude if missing
if [ -f "$CLAUDE_SETTINGS" ]; then
    HAS_WB="$(python3 -c "import json; d=json.load(open('$CLAUDE_SETTINGS')); print('yes' if 'workspace-brain' in d.get('mcpServers',{}) else 'no')" 2>/dev/null || echo 'no')"
    if [ "$HAS_WB" = "no" ]; then
        echo "Registering workspace-brain in Claude settings..."
        python3 - "$CLAUDE_SETTINGS" "$MCP_ROOT/server/main.py" <<'PY'
import json, sys, shutil
path = sys.argv[1]
server_main = sys.argv[2]
bak = path + ".bak-mcp-repair"
shutil.copy2(path, bak)
data = json.load(open(path))
data.setdefault("mcpServers", {})["workspace-brain"] = {
    "command": "uv",
    "args": ["run", "--with", "mcp==1.28.0", "python3", server_main]
}
open(path, "w").write(json.dumps(data, indent=2))
print("Done. Backup:", bak)
PY
        echo "[OK] Claude settings updated"
    else
        echo "[OK] Claude settings already has workspace-brain"
    fi
fi

# 4. Re-register with Codex if missing
if [ -f "$CODEX_CONFIG" ]; then
    if ! grep -q "workspace-brain" "$CODEX_CONFIG" 2>/dev/null; then
        echo "Registering workspace-brain in Codex config..."
        cp "$CODEX_CONFIG" "$CODEX_CONFIG.bak-mcp-repair"
        cat >> "$CODEX_CONFIG" <<TOML

# --- workspace-brain MCP server ---
[mcp_servers.workspace-brain]
command = "uv"
args = ["run", "--with", "mcp==1.28.0", "python3", "$MCP_ROOT/server/main.py"]
# --- end workspace-brain MCP server ---
TOML
        echo "[OK] Codex config updated"
    else
        echo "[OK] Codex config already has workspace-brain"
    fi
fi

# 5. Ensure state file initialized
if [ ! -f "$STATE" ]; then
    python3 -c "
import json, pathlib
from datetime import datetime, timezone
p = pathlib.Path('$STATE')
p.write_text(json.dumps({'server_version': '1.0.0', 'repaired_at': datetime.now(timezone.utc).astimezone().isoformat()}, indent=2)+'\n')
"
    echo "[OK] State file initialized"
fi

echo ""
echo "Repair complete. Run mcp-doctor to verify."
