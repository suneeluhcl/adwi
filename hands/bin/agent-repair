#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"
QUIET="${1:-}"

ensure_core_dirs

mkdir -p "$HOME/.codex" "$HOME/.claude"
for p in "$ROOT/AGENTS.md" "$ROOT/CLAUDE.md" "$HOME/.codex/AGENTS.md" "$HOME/.claude/CLAUDE.md"; do
  if [ -e "$p" ] && [ ! -L "$p" ]; then
    if ! grep -q "$CANON" "$p" 2>/dev/null; then
      backup_item "$p" >/dev/null
    fi
  fi
  ln -sfn "$CANON" "$p"
done

for s in agent-status agent-start agent-finish agent-doctor agent-repair agent-maintain agent-autoclose use-codex use-claude workspace-context workspace-backup workspace-index workspace-report workspace-changes agent-test-loop workflow-audit gstack-create; do
  [ -f "$ROOT/bin/$s" ] && chmod 755 "$ROOT/bin/$s"
done
[ -f "$ROOT/automation/maintenance/common.sh" ] && chmod 755 "$ROOT/automation/maintenance/common.sh"
if [ -d "$ROOT/autolab/scripts" ]; then
  chmod 755 "$ROOT"/autolab/scripts/autolab-* 2>/dev/null || true
fi

create_if_missing() {
  path="$1"
  title="$2"
  body="$3"
  if [ ! -e "$path" ]; then
    {
      echo "# $title"
      echo
      echo "$body"
    } > "$path"
  fi
}

create_if_missing "$ROOT/agent-system/memory/SESSION_HANDOFF.md" "Session Handoff" "No prior handoff was available. Read CURRENT_STATE.json and SESSION_LOG.md for additional context."
create_if_missing "$ROOT/agent-system/memory/MEMORY.md" "Shared Memory" "Durable workspace facts go here."
create_if_missing "$ROOT/agent-system/memory/DECISIONS.md" "Decisions" "Important decisions and reasons go here."
create_if_missing "$ROOT/agent-system/tasks/ACTIVE_TASKS.md" "Active Tasks" "Current workspace tasks go here."
create_if_missing "$ROOT/agent-system/tasks/COMPLETED_TASKS.md" "Completed Tasks" "Completed workspace tasks go here."
create_if_missing "$ROOT/agent-system/tasks/TASK_QUEUE.md" "Task Queue" "Future workspace tasks go here."
create_if_missing "$ROOT/agent-system/logs/SESSION_LOG.md" "Session Log" "Session activity is appended here."
create_if_missing "$ROOT/agent-system/logs/MAINTENANCE_LOG.md" "Maintenance Log" "Maintenance activity is appended here."
create_if_missing "$ROOT/agent-system/logs/CHANGE_LOG.md" "Change Log" "Important workspace changes go here."

python3 - "$ROOT" "$STATE_JSON" "$HEALTH_JSON" "$INDEX_JSON" <<'PY'
import json, pathlib, sys
from datetime import datetime
root = pathlib.Path(sys.argv[1])
state, health, index = map(pathlib.Path, sys.argv[2:5])
stamp = datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z")
defaults = {
    state: {
        "workspace_root": str(root),
        "canonical_instruction_file": str(root / "agent-system/shared/AGENT_SYSTEM.md"),
        "shared_memory_dir": str(root / "agent-system/memory"),
        "tasks_dir": str(root / "agent-system/tasks"),
        "logs_dir": str(root / "agent-system/logs"),
        "state_updated_at": stamp,
        "last_summary": "State file repaired or refreshed.",
        "active_agent": "unknown",
        "maintenance_enabled": False,
        "status": "repaired",
    },
    health: {
        "checked_at": stamp,
        "status": "unknown",
        "issue_count": 0,
        "issues": [],
        "repair_suggestions": [],
    },
    index: {
        "generated_at": stamp,
        "workspace_root": str(root),
        "entrypoints": [],
        "groups": {},
    },
    pathlib.Path(root / "agent-system/state/ACTIVE_SESSION.json"): {
        "active": False,
        "session_id": None,
        "repaired_at": stamp,
    },
    pathlib.Path(root / "agent-system/state/LAST_KNOWN_GOOD.json"): {
        "created_at": stamp,
        "status": "repaired-baseline",
        "validation": {},
    },
}
for path, default in defaults.items():
    needs_write = False
    if not path.exists():
        needs_write = True
    else:
        try:
            json.loads(path.read_text())
        except Exception:
            backup = root / ".agent-backups" / datetime.now().strftime("%Y%m%d-%H%M%S") / str(path).lstrip("/")
            backup.parent.mkdir(parents=True, exist_ok=True)
            backup.write_bytes(path.read_bytes())
            needs_write = True
    if needs_write:
        tmp = path.with_suffix(path.suffix + ".tmp")
        tmp.write_text(json.dumps(default, indent=2, sort_keys=True) + "\n")
        tmp.replace(path)
PY

"$ROOT/bin/workspace-index" --quiet >/dev/null 2>&1 || true
"$ROOT/bin/agent-doctor" --quiet >/dev/null 2>&1 || true
python3 "$ROOT/scripts/auto_repair_extensions.py" >/dev/null 2>&1 || true
python3 - "$HEALTH_JSON" <<'PY' >/dev/null 2>&1 || true
import json, pathlib, sys
from datetime import datetime
p = pathlib.Path(sys.argv[1])
try:
    data = json.loads(p.read_text())
except Exception:
    data = {}
data["last_repair_run"] = datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z")
data["auto_fixes_applied"] = int(data.get("auto_fixes_applied", 0)) + 1
tmp = p.with_suffix(p.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
tmp.replace(p)
PY
log_maintenance "Repair ran and completed safe repairs."

[ "$QUIET" = "--quiet" ] || echo "Safe repair completed."
