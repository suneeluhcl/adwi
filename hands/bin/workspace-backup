#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"
ensure_core_dirs

MODE="${1:-manual}"
QUIET="${2:-}"
ts="$(date '+%Y%m%d-%H%M%S')"
dest="$BACKUP_ROOT/$ts/workspace-core"
mkdir -p "$dest"

for p in README.md .gitignore agent-system bin automation; do
  if [ -e "$ROOT/$p" ] || [ -L "$ROOT/$p" ]; then
    cp -a "$ROOT/$p" "$dest/"
  fi
done

log_maintenance "Workspace backup created at $dest ($MODE)."
[ "$QUIET" = "--quiet" ] || echo "$dest"
