#!/bin/sh
# Print a concise MCP subsystem capability and health report.
set -eu
# Resolve symlinks to get the real directory of this script
TARGET="$0"
while [ -L "$TARGET" ]; do
    DIR="$(dirname "$TARGET")"
    TARGET="$(readlink "$TARGET")"
    case "$TARGET" in
        /*) ;;
        *) TARGET="$DIR/$TARGET" ;;
    esac
done
MCP_ROOT="$(cd "$(dirname "$TARGET")/../.." && pwd)"
DB="$MCP_ROOT/server/storage/memory_index.db"
STATE="$MCP_ROOT/server/state/mcp_state.json"
INDEX_META="$MCP_ROOT/server/state/last_index.json"
LOG="$MCP_ROOT/server/logs/mcp_server.log"

echo "============================================"
echo "  workspace-brain MCP Capability Report"
echo "  $(date)"
echo "============================================"
echo ""

echo "## Server"
echo "  Entrypoint: $MCP_ROOT/server/main.py"
echo "  Runtime: uv run --with-requirements server/requirements.txt (mcp==1.28.0)"
echo "  Mode: stdio (clients start on demand)"
echo ""

echo "## Resources ($(python3 -c "import json; d=json.load(open('$MCP_ROOT/server/config/resource_map.json')); print(len(d['resources']))" 2>/dev/null || echo '?'))"
python3 -c "
import json
d = json.load(open('$MCP_ROOT/server/config/resource_map.json'))
for uri, info in d['resources'].items():
    print(f'  {uri:<40} {info[\"label\"]}')
" 2>/dev/null || echo "  (could not load resource map)"
echo ""

echo "## Tools"
python3 -c "
import json
d = json.load(open('$MCP_ROOT/server/config/tool_policies.json'))
for tool, perms in d['tool_permissions'].items():
    flags = []
    if perms['read']: flags.append('read')
    if perms['write']: flags.append('write')
    if perms['exec']: flags.append('exec')
    print(f'  {tool:<40} [{\" \".join(flags)}]')
" 2>/dev/null || echo "  (could not load tool policies)"
echo ""

echo "## Index"
if [ -f "$DB" ]; then
    python3 -c "
import sqlite3
conn = sqlite3.connect('$DB')
total = conn.execute('SELECT COUNT(*) FROM entries').fetchone()[0]
cats = conn.execute('SELECT category, COUNT(*) FROM entries GROUP BY category ORDER BY 2 DESC').fetchall()
print(f'  Total entries: {total}')
for cat, count in cats:
    print(f'  {cat}: {count}')
" 2>/dev/null || echo "  (error reading index)"
else
    echo "  Index not built (run mcp-reindex)"
fi
echo ""

echo "## Last Reindex"
if [ -f "$INDEX_META" ]; then
    python3 -c "import json; d=json.load(open('$INDEX_META')); print(f'  {d.get(\"indexed_at\",\"?\")}, {d.get(\"total_entries\",\"?\")} entries')" 2>/dev/null
else
    echo "  Not yet run"
fi
echo ""

echo "## Client Registration"
python3 -c "
import json
try:
    d = json.load(open('$HOME/.claude/settings.json'))
    reg = d.get('mcpServers', {}).get('workspace-brain')
    if reg:
        print(f'  Claude: registered ({reg[\"command\"]} {\" \".join(reg[\"args\"][:3])}...)')
    else:
        print('  Claude: NOT REGISTERED')
except Exception as e:
    print(f'  Claude: error ({e})')
" 2>/dev/null

python3 -c "
import pathlib
cfg = pathlib.Path('$HOME/.codex/config.toml').read_text()
if 'workspace-brain' in cfg:
    print('  Codex: registered')
else:
    print('  Codex: NOT REGISTERED')
" 2>/dev/null
echo ""

echo "## Recent Log (last 10 lines)"
[ -f "$LOG" ] && tail -10 "$LOG" | sed 's/^/  /' || echo "  (no log yet)"

echo ""
echo "============================================"

# Write capability report to file
python3 - "$MCP_ROOT" <<'PY'
import json, pathlib, sys
from datetime import datetime, timezone
root = pathlib.Path(sys.argv[1])
try:
    rm = json.loads((root / "server/config/resource_map.json").read_text())
    tp = json.loads((root / "server/config/tool_policies.json").read_text())
    report = {
        "generated_at": datetime.now(timezone.utc).astimezone().isoformat(),
        "resource_count": len(rm["resources"]),
        "tool_count": len(tp["tool_permissions"]),
        "resources": list(rm["resources"].keys()),
        "tools": list(tp["tool_permissions"].keys()),
    }
    (root / "server/state/capability_report.json").write_text(json.dumps(report, indent=2)+"\n")
except Exception as e:
    print(f"  (capability_report not written: {e})")
PY
