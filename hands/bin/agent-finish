#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"

SUMMARY="${*:-}"
if [ -z "$SUMMARY" ]; then
  printf 'Short session summary: '
  IFS= read -r SUMMARY
fi

if [ -z "$SUMMARY" ]; then
  echo "No summary provided; nothing changed." >&2
  exit 1
fi

ensure_core_dirs
DATE="$(today)"
STAMP="$(now_stamp)"
HANDOFF="$ROOT/agent-system/memory/SESSION_HANDOFF.md"

tmp="$HANDOFF.tmp"
cat > "$tmp" <<EOF
# Session Handoff

## Latest Handoff

Date: $DATE

Summary: $SUMMARY

Changed:

- See \`agent-system/logs/SESSION_LOG.md\` for the session entry.

Verification:

- Run \`~/SuneelWorkSpace/bin/agent-status\` or \`~/SuneelWorkSpace/bin/agent-doctor\`.

Open Items:

- Review \`agent-system/tasks/ACTIVE_TASKS.md\` and \`agent-system/tasks/TASK_QUEUE.md\`.
EOF
mv "$tmp" "$HANDOFF"

log_session "$SUMMARY"

python3 - "$STATE_JSON" "$STAMP" "$SUMMARY" <<'PY'
import json, pathlib, sys
path = pathlib.Path(sys.argv[1])
stamp = sys.argv[2]
summary = sys.argv[3]
try:
    data = json.loads(path.read_text())
except Exception:
    data = {}
data.update({
    "state_updated_at": stamp,
    "last_summary": summary,
    "status": "handoff-updated",
})
tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
tmp.replace(path)
PY

"$ROOT/bin/workspace-index" --quiet >/dev/null 2>&1 || true
"$ROOT/bin/workspace-report" --quiet >/dev/null 2>&1 || true

echo "Updated handoff, session log, current state, index, and latest report."
