#!/bin/sh
# Health check for the workspace-brain MCP subsystem.
set -eu
# Resolve symlinks to get the real directory of this script
TARGET="$0"
while [ -L "$TARGET" ]; do
    DIR="$(dirname "$TARGET")"
    TARGET="$(readlink "$TARGET")"
    case "$TARGET" in
        /*) ;;
        *) TARGET="$DIR/$TARGET" ;;
    esac
done
MCP_ROOT="$(cd "$(dirname "$TARGET")/../.." && pwd)"
DB="$MCP_ROOT/server/storage/memory_index.db"
STATE="$MCP_ROOT/server/state/mcp_state.json"
CFG="$MCP_ROOT/server/config/server_config.json"
POLICIES="$MCP_ROOT/server/config/tool_policies.json"
RESOURCE_MAP="$MCP_ROOT/server/config/resource_map.json"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
CODEX_CONFIG="$HOME/.codex/config.toml"

ISSUES=0
WARNINGS=0

check() {
    LABEL="$1"
    RESULT="$2"
    if [ "$RESULT" = "ok" ]; then
        echo "  [OK]  $LABEL"
    elif [ "$RESULT" = "warn" ]; then
        echo "  [WARN] $LABEL"
        WARNINGS=$((WARNINGS+1))
    else
        echo "  [FAIL] $LABEL"
        ISSUES=$((ISSUES+1))
    fi
}

echo "=== workspace-brain MCP Doctor ==="
echo ""
echo "-- Config --"

[ -f "$CFG" ] && check "server_config.json exists" "ok" || check "server_config.json exists" "fail"
[ -f "$POLICIES" ] && check "tool_policies.json exists" "ok" || check "tool_policies.json exists" "fail"
[ -f "$RESOURCE_MAP" ] && check "resource_map.json exists" "ok" || check "resource_map.json exists" "fail"
[ -f "$MCP_ROOT/server/main.py" ] && check "main.py exists" "ok" || check "main.py exists" "fail"

# Validate JSON configs
python3 -c "import json; json.load(open('$CFG'))" 2>/dev/null && check "server_config.json valid JSON" "ok" || check "server_config.json valid JSON" "fail"
python3 -c "import json; json.load(open('$POLICIES'))" 2>/dev/null && check "tool_policies.json valid JSON" "ok" || check "tool_policies.json valid JSON" "fail"
python3 -c "import json; json.load(open('$RESOURCE_MAP'))" 2>/dev/null && check "resource_map.json valid JSON" "ok" || check "resource_map.json valid JSON" "fail"

echo ""
echo "-- Index --"
if [ -f "$DB" ]; then
    COUNT="$(python3 -c "import sqlite3; c=sqlite3.connect('$DB'); print(c.execute('SELECT COUNT(*) FROM entries').fetchone()[0])" 2>/dev/null || echo 0)"
    if [ "$COUNT" -gt 0 ] 2>/dev/null; then
        check "Index exists with $COUNT entries" "ok"
    else
        check "Index exists but is empty (run mcp-reindex)" "warn"
    fi
else
    check "Index not found (run mcp-reindex)" "warn"
    WARNINGS=$((WARNINGS+1))
fi

echo ""
echo "-- Client Registration --"
if [ -f "$CLAUDE_SETTINGS" ]; then
    python3 -c "import json; d=json.load(open('$CLAUDE_SETTINGS')); assert 'workspace-brain' in d.get('mcpServers',{})" 2>/dev/null \
        && check "Claude settings.json has workspace-brain" "ok" \
        || check "Claude settings.json missing workspace-brain" "fail"
else
    check "Claude settings.json not found" "warn"
fi

if [ -f "$CODEX_CONFIG" ]; then
    grep -q "workspace-brain" "$CODEX_CONFIG" 2>/dev/null \
        && check "Codex config.toml has workspace-brain" "ok" \
        || check "Codex config.toml missing workspace-brain" "fail"
else
    check "Codex config.toml not found" "warn"
fi

echo ""
echo "-- Log Permissions --"
LOG_DIR="$MCP_ROOT/server/logs"
[ -d "$LOG_DIR" ] && [ -w "$LOG_DIR" ] && check "Log directory writable" "ok" || check "Log directory not writable" "fail"

echo ""
echo "-- Workspace Source Files --"
for REL in \
    "agent-system/memory/MEMORY.md" \
    "agent-system/memory/DECISIONS.md" \
    "agent-system/tasks/ACTIVE_TASKS.md" \
    "agent-system/state/CURRENT_STATE.json" \
    "agent-system/state/WORKSPACE_HEALTH.json"
do
    FULL="$HOME/SuneelWorkSpace/$REL"
    [ -f "$FULL" ] && check "$REL" "ok" || check "$REL (missing)" "warn"
done

echo ""
echo "-- MCP Python Dependency --"
uv run --with-requirements "$HOME/SuneelWorkSpace/mcp/server/requirements.txt" python3 -c "import mcp; print('mcp', mcp.__version__ if hasattr(mcp,'__version__') else 'ok')" 2>/dev/null \
    && check "mcp package installable via uv" "ok" \
    || check "mcp package not available (check uv/network)" "fail"

echo ""
echo "==================================="
echo "Issues: $ISSUES | Warnings: $WARNINGS"
if [ "$ISSUES" -eq 0 ] && [ "$WARNINGS" -eq 0 ]; then
    echo "Status: HEALTHY"
    exit 0
elif [ "$ISSUES" -eq 0 ]; then
    echo "Status: OK (with warnings)"
    exit 0
else
    echo "Status: ISSUES DETECTED — run mcp-repair"
    exit 1
fi
