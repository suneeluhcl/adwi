#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"

ensure_core_dirs

if [ ! -f "$HEALTH_JSON" ] || ! python3 -m json.tool "$HEALTH_JSON" >/dev/null 2>&1; then
  "$ROOT/bin/agent-doctor" --quiet >/dev/null 2>&1 || true
fi


echo "Workspace: $ROOT"
echo "Canonical instructions: $CANON"
echo
echo "Entrypoints:"
for p in "$ROOT/AGENTS.md" "$ROOT/CLAUDE.md" "$HOME/.codex/AGENTS.md" "$HOME/.claude/CLAUDE.md"; do
  if [ -L "$p" ]; then
    printf 'OK   %s -> %s\n' "$p" "$(readlink "$p")"
  elif [ -e "$p" ]; then
    printf 'WARN %s exists but is not a symlink\n' "$p"
  else
    printf 'MISS %s\n' "$p"
  fi
done

echo
echo "Health:"
python3 - "$HEALTH_JSON" <<'PY'
import json, sys
from pathlib import Path
p = Path(sys.argv[1])
try:
    data = json.loads(p.read_text())
except Exception as exc:
    print(f"Unable to read health: {exc}")
    raise SystemExit(0)
print(f"status: {data.get('status', 'unknown')}")
print(f"checked_at: {data.get('checked_at', 'unknown')}")
print(f"issue_count: {data.get('issue_count', 0)}")
for issue in data.get("issues", [])[:8]:
    print(f"- {issue.get('severity', 'info')}: {issue.get('message', issue)}")
PY

echo
echo "Current state:"
python3 - "$STATE_JSON" <<'PY'
import json, sys
from pathlib import Path
p = Path(sys.argv[1])
try:
    data = json.loads(p.read_text())
except Exception as exc:
    print(f"Unable to read state: {exc}")
    raise SystemExit(0)
for k in ("status", "active_session_detected", "session_started_at", "last_activity_timestamp", "last_auto_closeout_timestamp", "last_summary", "state_updated_at", "active_agent", "maintenance_enabled"):
    print(f"{k}: {data.get(k, 'unknown')}")
PY

echo
echo "Recent handoff:"
sed -n '1,60p' "$ROOT/agent-system/memory/SESSION_HANDOFF.md"

echo
echo "Active tasks:"
sed -n '1,80p' "$ROOT/agent-system/tasks/ACTIVE_TASKS.md"

echo
echo "Goal Engine:"
python3 - "$ROOT/goal-engine/state/goal_state.json" "$ROOT/goal-engine/state/current_goal.json" "$ROOT/goal-engine/graph/task_graph.json" <<'PY'
import json, pathlib, sys
state_path = pathlib.Path(sys.argv[1])
current_path = pathlib.Path(sys.argv[2])
graph_path = pathlib.Path(sys.argv[3])
try:
    state = json.loads(state_path.read_text())
    print(f"active_goals: {state.get('active_goal_count', 0)}")
    print(f"completed_goals: {state.get('completed_goal_count', 0)}")
    print(f"tasks_executed: {state.get('total_tasks_executed', 0)}")
    print(f"last_execution: {state.get('last_execution_at', 'never')}")
except Exception:
    print("state: not found")
try:
    current = json.loads(current_path.read_text())
    gid = current.get('goal_id')
    if gid:
        print(f"current_goal: {gid} — {current.get('goal_description', '')[:50]}")
        ready = current.get('ready_tasks', [])
        if ready:
            print(f"ready_tasks: {', '.join(ready)}")
except Exception:
    pass
PY

echo
echo "Orchestrator:"
python3 - "$ROOT/orchestrator/state/current_routing_state.json" "$ROOT/orchestrator/router/history.json" "$ROOT/orchestrator/models/routing_patterns.json" <<'PY'
import json, pathlib, sys
state_path = pathlib.Path(sys.argv[1])
history_path = pathlib.Path(sys.argv[2])
patterns_path = pathlib.Path(sys.argv[3])
try:
    state = json.loads(state_path.read_text())
    print(f"last_agent: {state.get('last_agent', 'none')}")
    print(f"last_task_type: {state.get('last_task_type', 'none')}")
    print(f"last_learn_at: {state.get('last_learn_at', 'never')}")
except Exception:
    print("state: not found")
try:
    h = json.loads(history_path.read_text())
    print(f"routing_decisions: {h.get('_meta',{}).get('entry_count', 0)}")
    entries = h.get("entries", [])
    if entries:
        last = entries[-1]
        print(f"last_decision: {last.get('agent','?').upper()} for {last.get('task_type','?')} ({last.get('confidence',0):.0%})")
except Exception:
    print("history: not found")
try:
    p = json.loads(patterns_path.read_text())
    print(f"learned_patterns: {len(p.get('patterns',{}))}")
except Exception:
    pass
PY

echo
echo "MCP subsystem:"
python3 - "$ROOT/mcp/server/state/mcp_state.json" "$ROOT/mcp/server/storage/memory_index.db" "$ROOT/mcp/server/state/last_index.json" <<'PY'
import json, pathlib, sys
state_path = pathlib.Path(sys.argv[1])
db_path = pathlib.Path(sys.argv[2])
idx_path = pathlib.Path(sys.argv[3])
try:
    state = json.loads(state_path.read_text())
    print(f"started: {state.get('server_started_at', 'never')}")
    print(f"last_reindex: {state.get('last_reindex', 'never')}")
except Exception:
    print("state: not found")
if db_path.exists():
    try:
        import sqlite3
        conn = sqlite3.connect(str(db_path))
        count = conn.execute("SELECT COUNT(*) FROM entries").fetchone()[0]
        print(f"index entries: {count}")
        conn.close()
    except Exception:
        print("index: error")
else:
    print("index: not built")
try:
    meta = json.loads(idx_path.read_text())
    print(f"indexed_at: {meta.get('indexed_at','?')}")
except Exception:
    pass
PY

if [ -f "$ROOT/autolab/state/latest_eval.json" ]; then
  echo
  echo "Autolab:"
  python3 - "$ROOT/autolab/state/latest_eval.json" "$ROOT/autolab/state/loop_status.json" <<'PY'
import json, pathlib, sys
eval_path = pathlib.Path(sys.argv[1])
status_path = pathlib.Path(sys.argv[2])
try:
    data = json.loads(eval_path.read_text())
except Exception as exc:
    print(f"latest_eval unavailable: {exc}")
    raise SystemExit(0)
try:
    status = json.loads(status_path.read_text())
except Exception:
    status = {}
print(f"score: {data.get('score', 'unknown')} / {data.get('max_score', 100)}")
print(f"gates_passed: {data.get('gates_passed', 'unknown')}")
print(f"loop_status: {status.get('status', 'unknown')}")
print("report: autolab/reports/latest_report.md")
PY
fi
if [ -f "$ROOT/scripts/system_intelligence.py" ]; then
  python3 "$ROOT/scripts/system_intelligence.py" status 2>/dev/null || true
fi
