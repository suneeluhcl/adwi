#!/usr/bin/env bash
# jupyter-mcp — Jupyter notebook connector (CONTROLLED — confirms before execution)
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/SuneelWorkSpace}"
NOTEBOOK_DIR="$WORKSPACE/projects"
OUTPUT_DIR="$WORKSPACE/research-engine/analyses/notebook_outputs"

mkdir -p "$OUTPUT_DIR"

if ! python3 -c "import jupyter" 2>/dev/null && ! command -v jupyter &>/dev/null; then
  echo "❌ Jupyter not installed."
  echo "   Install: pip3 install jupyter --break-system-packages"
  DISCOVER="$WORKSPACE/brain/system/tool_discovery.md"
  if [[ -f "$DISCOVER" ]] && ! grep -q "jupyter" "$DISCOVER"; then
    echo -e "\n## Jupyter\n- Status: NOT INSTALLED\n- Install: pip3 install jupyter\n- Required for: notebook execution via MCP" >> "$DISCOVER"
  fi
  exit 1
fi

cmd="${1:-list}"
shift || true

case "$cmd" in
  list)
    echo "=== Notebooks in projects/ ==="
    find "$NOTEBOOK_DIR" -name "*.ipynb" 2>/dev/null | while read -r nb; do
      echo "  $(realpath --relative-to="$WORKSPACE" "$nb")"
    done
    echo ""
    echo "Resource: workspace://jupyter/notebooks"
    ;;

  execute)
    NOTEBOOK="${1:-}"
    if [[ -z "$NOTEBOOK" ]]; then
      echo "Usage: jupyter-mcp execute <notebook.ipynb>"
      exit 1
    fi
    echo "⚠️  CONTROLLED: About to execute notebook: $NOTEBOOK"
    read -r -p "Confirm? (y/N) " reply
    if [[ "$reply" =~ ^[Yy]$ ]]; then
      TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
      BASENAME=$(basename "$NOTEBOOK" .ipynb)
      OUTPUT="$OUTPUT_DIR/${BASENAME}_${TIMESTAMP}.ipynb"
      jupyter nbconvert --to notebook --execute "$NOTEBOOK" --output "$OUTPUT" 2>&1
      echo "✅ Output saved → $OUTPUT"
    else
      echo "Cancelled."
    fi
    ;;

  *)
    echo "Usage: jupyter-mcp [list|execute <notebook.ipynb>]"
    ;;
esac
