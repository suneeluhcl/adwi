#!/usr/bin/env python3
"""Generate a communications subsystem report."""
import sys
import json
import pathlib
import sqlite3
from datetime import datetime, timedelta, timezone

ROOT = pathlib.Path.home() / "SuneelWorkSpace"
DB = pathlib.Path.home() / "Library/Messages/chat.db"
REPORT = ROOT / "comms/reports/latest_comms_report.md"
APPLE_EPOCH_OFFSET = 978307200


def _imessage_stats():
    if not DB.exists():
        return {"error": "chat.db not found"}
    try:
        conn = sqlite3.connect(str(DB))
        c = conn.cursor()
        c.execute("SELECT count(*) FROM message")
        total = c.fetchone()[0]
        cutoff = (int((datetime.now() - timedelta(hours=24)).timestamp()) - APPLE_EPOCH_OFFSET) * 1_000_000_000
        c.execute("SELECT count(*) FROM message WHERE date > ?", (cutoff,))
        recent = c.fetchone()[0]
        c.execute("SELECT count(*) FROM message WHERE date > ? AND is_from_me = 0 AND is_read = 0", (cutoff,))
        unread = c.fetchone()[0]
        conn.close()
        return {"total": total, "last_24h": recent, "unread_24h": unread}
    except Exception as e:
        return {"error": str(e)}


def main():
    now = datetime.now(timezone.utc)
    stats = _imessage_stats()
    mail_app = pathlib.Path("/Applications/Mail.app")

    outbound_log = ROOT / "comms/imessage/logs/imessage_outbound.log"
    sent = 0
    if outbound_log.exists():
        try:
            sent = sum(1 for l in outbound_log.read_text().splitlines() if "SENT" in l)
        except Exception:
            pass

    lines = [
        f"# Communications Report",
        f"Generated: {now.strftime('%Y-%m-%d %H:%M UTC')}",
        "",
        "## iMessage",
        f"- Total messages in DB: {stats.get('total', 'N/A')}",
        f"- Messages (last 24h): {stats.get('last_24h', 'N/A')}",
        f"- Unread (last 24h): {stats.get('unread_24h', 'N/A')}",
        f"- Sent via workspace: {sent}",
        f"- FDA status: {'granted' if 'error' not in stats else 'error: ' + stats.get('error', '')}",
        "",
        "## Mail",
        f"- Mail.app: {'installed' if mail_app.exists() else 'NOT installed'}",
        "- Status: disabled until Mail.app is configured",
        "- See: comms/reports/plugin_recommendations.md for options",
        "",
        "## Safety",
        "- Auto-send: DISABLED",
        "- Auto-reply: DISABLED",
        "- Confirmation required: YES",
        "- Body logging: DISABLED",
        "",
        "## Next Steps",
        "- Run: comms-permissions-check — verify all permissions",
        "- Run: comms-doctor — check subsystem health",
        "- Optional: install iMessage Claude plugin via bin/install-imessage-plugin",
    ]

    report_text = "\n".join(lines)
    REPORT.parent.mkdir(parents=True, exist_ok=True)
    REPORT.write_text(report_text)

    print(report_text)
    print()
    print(f"Report saved: {REPORT}")


if __name__ == "__main__":
    main()
