#!/usr/bin/env bash
# mesh-assign — Manually assign a task to an agent
# Usage: mesh-assign <task_id> <agent>
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/SuneelWorkSpace}"
QUEUE="$WORKSPACE/orchestrator/mesh/task_queue.json"

TASK_ID="${1:-}"
AGENT="${2:-}"

if [[ -z "$TASK_ID" || -z "$AGENT" ]]; then
  echo "Usage: mesh-assign <task_id> <agent>"
  echo "Agents: claude, codex, gemini, opencode, antigravity"
  exit 1
fi

NOW=$(date -u +"%Y-%m-%dT%H:%M:%S")
python3 - "$TASK_ID" "$AGENT" "$NOW" "$QUEUE" <<'EOF'
import json, sys
task_id, agent, now, queue_file = sys.argv[1:]
with open(queue_file) as f:
    data = json.load(f)
found = False
for t in data['queue']:
    if t.get('task_id') == task_id or t.get('task_id', '').startswith(task_id):
        t['assigned_agent'] = agent
        t['last_updated'] = now
        t['status'] = 'pending'
        found = True
        print(f"✅ Task {task_id} assigned to {agent}")
if not found:
    print(f"❌ Task '{task_id}' not found in queue")
    sys.exit(1)
with open(queue_file, 'w') as f:
    json.dump(data, f, indent=2)
EOF
