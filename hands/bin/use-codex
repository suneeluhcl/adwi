#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
cd "$ROOT"
"$ROOT/bin/agent-start" || true

if command -v codex >/dev/null 2>&1; then
  set +e
  codex
  code=$?
  set -e
  "$ROOT/bin/agent-autoclose" --wrapper codex --exit-code "$code" || true
  exit "$code"
fi

cat <<EOF
Codex CLI was not found on PATH.

You are already in:
$ROOT

Install or expose Codex CLI on PATH, then run:
codex
EOF
"$ROOT/bin/agent-autoclose" --wrapper codex-missing --exit-code 127 >/dev/null 2>&1 || true
