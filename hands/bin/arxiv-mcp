#!/usr/bin/env bash
# arxiv-mcp — Arxiv research paper connector
# Usage: arxiv-mcp "<search query>" [--download]
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/SuneelWorkSpace}"
RESULTS_DIR="$WORKSPACE/research-engine/plans"
PAPERS_DIR="$WORKSPACE/research-engine/analyses/papers"

mkdir -p "$RESULTS_DIR" "$PAPERS_DIR"

QUERY="${1:-}"
DOWNLOAD="${2:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage: arxiv-mcp \"<search query>\" [--download]"
  echo "Example: arxiv-mcp \"retrieval augmented generation 2024\""
  exit 1
fi

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
OUTPUT_FILE="$RESULTS_DIR/arxiv_results_${TIMESTAMP}.json"

echo "🔍 Searching Arxiv for: $QUERY"

# URL-encode the query
ENCODED_QUERY=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$QUERY'))")

# Fetch from Arxiv API
RESPONSE=$(curl -sf "https://export.arxiv.org/api/query?search_query=all:${ENCODED_QUERY}&start=0&max_results=5&sortBy=submittedDate&sortOrder=descending" 2>/dev/null || echo "")

if [[ -z "$RESPONSE" ]]; then
  echo "❌ Could not reach Arxiv API. Check your internet connection."
  exit 1
fi

# Parse with Python
python3 << PYEOF
import xml.etree.ElementTree as ET
import json
import sys

response = """$RESPONSE"""
ns = {'atom': 'http://www.w3.org/2005/Atom', 'arxiv': 'http://arxiv.org/schemas/atom'}

try:
    root = ET.fromstring(response)
    entries = root.findall('atom:entry', ns)
    results = []
    for entry in entries:
        title = entry.find('atom:title', ns)
        summary = entry.find('atom:summary', ns)
        published = entry.find('atom:published', ns)
        authors = entry.findall('atom:author', ns)
        links = entry.findall('atom:link', ns)
        
        pdf_url = None
        for link in links:
            if link.get('type') == 'application/pdf':
                pdf_url = link.get('href')
                break
        
        entry_id = entry.find('atom:id', ns)
        
        result = {
            'title': (title.text or '').strip().replace('\n', ' '),
            'authors': [a.find('atom:name', ns).text for a in authors[:5]],
            'abstract': (summary.text or '').strip().replace('\n', ' ')[:500] + '...',
            'published': (published.text or '')[:10],
            'arxiv_url': entry_id.text if entry_id is not None else '',
            'pdf_url': pdf_url
        }
        results.append(result)
    
    print(json.dumps(results, indent=2))
    
    # Print summary
    print(f"\n{'='*60}", file=sys.stderr)
    print(f"Found {len(results)} papers:", file=sys.stderr)
    for i, r in enumerate(results, 1):
        print(f"  {i}. {r['title'][:70]}", file=sys.stderr)
        print(f"     {r['published']} | {', '.join(r['authors'][:2])}", file=sys.stderr)
except Exception as e:
    print(f"Parse error: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF | tee "$OUTPUT_FILE" > /dev/null

python3 - "$OUTPUT_FILE" << 'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    results = json.load(f)
print(f"\n{'='*60}")
print(f"Found {len(results)} papers:")
for i, r in enumerate(results, 1):
    print(f"\n  {i}. {r['title'][:70]}")
    print(f"     Date: {r['published']}")
    print(f"     Authors: {', '.join(r['authors'][:2])}")
    print(f"     URL: {r['arxiv_url']}")
PYEOF

echo ""
echo "✅ Results saved → $OUTPUT_FILE"
echo "   Resource: workspace://research/arxiv"

if [[ "$DOWNLOAD" == "--download" ]]; then
  echo ""
  echo "⚠️  Paper download not yet implemented. Visit the URLs above to download PDFs."
fi
