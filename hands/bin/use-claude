#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
cd "$ROOT"
"$ROOT/bin/agent-start" || true

if command -v claude >/dev/null 2>&1; then
  set +e
  claude
  code=$?
  set -e
  "$ROOT/bin/agent-autoclose" --wrapper claude --exit-code "$code" || true
  exit "$code"
fi

cat <<EOF
Claude Code CLI was not found on PATH.

You are already in:
$ROOT

Install or expose Claude Code on PATH, then run:
claude
EOF
"$ROOT/bin/agent-autoclose" --wrapper claude-missing --exit-code 127 >/dev/null 2>&1 || true
