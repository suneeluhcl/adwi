#!/bin/sh
ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
python3 "$ROOT/comms/imessage/scripts/imessage-send-draft" "$@"
STATUS="$?"
python3 "$ROOT/identity/adaptive/adaptive_identity.py" hook \
  --output-id "imessage-draft-$(date '+%Y%m%d%H%M%S')" \
  --context "comms_imessage_draft" \
  --agent "Codex" \
  --notes "imessage draft flow completed with exit code $STATUS" >/dev/null 2>&1 || true
python3 "$ROOT/anticipation/prediction_engine.py" record \
  --command imessage-send-draft \
  --context comms \
  --exit-code "$STATUS" 2>/dev/null || true
exit "$STATUS"
