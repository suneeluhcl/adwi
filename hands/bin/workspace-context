#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"

echo "Shared workspace context"
echo "Root: $ROOT"
echo
echo "Read these files first, in order:"
cat <<EOF
1. $ROOT/agent-system/shared/AGENT_SYSTEM.md
2. $ROOT/agent-system/shared/IDENTITY.md
3. $ROOT/agent-system/shared/WORKFLOW_RULES.md
4. $ROOT/agent-system/shared/SAFETY_BOUNDARIES.md
5. $ROOT/agent-system/shared/STARTUP_CHECKLIST.md
6. $ROOT/agent-system/memory/MEMORY.md
7. $ROOT/agent-system/memory/DECISIONS.md
8. $ROOT/agent-system/tasks/ACTIVE_TASKS.md
9. $ROOT/agent-system/tasks/TASK_QUEUE.md
10. $ROOT/agent-system/memory/SESSION_HANDOFF.md
11. $ROOT/agent-system/state/CURRENT_STATE.json
12. $ROOT/agent-system/state/WORKSPACE_HEALTH.json
EOF

echo
echo "Compact state:"
python3 - "$STATE_JSON" "$HEALTH_JSON" <<'PY'
import json, sys
from pathlib import Path
for label, path in (("state", Path(sys.argv[1])), ("health", Path(sys.argv[2]))):
    try:
        data = json.loads(path.read_text())
    except Exception as exc:
        print(f"{label}: unavailable ({exc})")
        continue
    if label == "state":
        print(f"status: {data.get('status', 'unknown')}")
        print(f"last_summary: {data.get('last_summary', 'unknown')}")
    else:
        print(f"health: {data.get('status', 'unknown')} ({data.get('issue_count', 0)} issues)")
PY

echo
echo "Use:"
echo "- $ROOT/bin/agent-status"
echo "- $ROOT/bin/agent-finish \"summary\""
