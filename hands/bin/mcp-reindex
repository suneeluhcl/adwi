#!/bin/sh
# Rebuild the workspace knowledge index from authoritative files.
set -eu
# Resolve real path of this script even when invoked via symlink
REAL_SCRIPT="$(python3 -c "import os,sys; print(os.path.realpath('$0'))")"
MCP_ROOT="$(cd "$(dirname "$REAL_SCRIPT")/../.." && pwd)"
echo "Rebuilding workspace-brain index..."
python3 - "$MCP_ROOT" <<'PY'
import sys, pathlib
sys.path.insert(0, str(pathlib.Path(sys.argv[1]) / "server"))
# We run reindex directly to avoid starting the full MCP server
import sqlite3, json, re, pathlib, shutil
from datetime import datetime, timezone

ROOT = pathlib.Path(sys.argv[1])
SERVER = ROOT / "server"
WORKSPACE = pathlib.Path("/Users/MAC/SuneelWorkSpace")
AUTOLAB = WORKSPACE / "autolab"
AGENT_SYS = WORKSPACE / "agent-system"
DB = SERVER / "storage" / "memory_index.db"
DB.parent.mkdir(parents=True, exist_ok=True)

def now(): return datetime.now(timezone.utc).astimezone().isoformat()

conn = sqlite3.connect(str(DB))
conn.execute("""CREATE TABLE IF NOT EXISTS entries (
    id INTEGER PRIMARY KEY AUTOINCREMENT, source TEXT, section TEXT,
    category TEXT, tags TEXT, content TEXT, indexed_at TEXT)""")
try:
    conn.execute("""CREATE VIRTUAL TABLE IF NOT EXISTS entries_fts
        USING fts5(source, section, category, tags, content, content='entries', content_rowid='id')""")
    conn.execute("""CREATE TRIGGER IF NOT EXISTS entries_ai AFTER INSERT ON entries BEGIN
        INSERT INTO entries_fts(rowid, source, section, category, tags, content)
        VALUES (new.id, new.source, new.section, new.category, new.tags, new.content); END""")
except Exception:
    pass
conn.execute("DELETE FROM entries")
try: conn.execute("DELETE FROM entries_fts")
except: pass
conn.commit()

sources = [
    ("agent-system/shared/AGENT_SYSTEM.md", "instructions", "workspace-overview"),
    ("agent-system/shared/IDENTITY.md", "instructions", "identity"),
    ("agent-system/shared/WORKFLOW_RULES.md", "instructions", "workflow-rules"),
    ("agent-system/shared/SAFETY_BOUNDARIES.md", "instructions", "safety-boundaries"),
    ("agent-system/shared/STARTUP_CHECKLIST.md", "instructions", "startup-checklist"),
    ("agent-system/memory/MEMORY.md", "memory", "memory"),
    ("agent-system/memory/DECISIONS.md", "memory", "decisions"),
    ("agent-system/memory/SESSION_HANDOFF.md", "memory", "session-handoff"),
    ("agent-system/memory/NOTES.md", "memory", "notes"),
    ("agent-system/tasks/ACTIVE_TASKS.md", "tasks", "active-tasks"),
    ("agent-system/tasks/TASK_QUEUE.md", "tasks", "task-queue"),
    ("agent-system/tasks/COMPLETED_TASKS.md", "tasks", "completed-tasks"),
    ("agent-system/state/CURRENT_STATE.json", "state", "current-state"),
    ("agent-system/state/WORKSPACE_HEALTH.json", "state", "workspace-health"),
    ("autolab/current_frontier.md", "autolab", "autolab-frontier"),
    ("autolab/program.md", "autolab", "autolab-program"),
    ("autolab/meta/insights.md", "autolab", "autolab-insights"),
    ("autolab/meta/patterns.json", "autolab", "autolab-patterns"),
    ("autolab/meta/failure_patterns.json", "autolab", "autolab-failures"),
    ("autolab/meta/learning_log.md", "autolab", "autolab-learning"),
    ("autolab/results.tsv", "autolab", "autolab-results"),
    ("agent-system/logs/SESSION_LOG.md", "logs", "session-log"),
    ("orchestrator/router/router.md", "orchestrator", "router-guide"),
    ("orchestrator/router/decision_policy.md", "orchestrator", "decision-policy"),
    ("orchestrator/router/agent_profiles.json", "orchestrator", "agent-profiles"),
    ("orchestrator/router/task_types.json", "orchestrator", "task-types"),
    ("orchestrator/models/routing_patterns.json", "orchestrator", "routing-patterns"),
    ("orchestrator/reports/agent_performance.md", "orchestrator", "agent-performance"),
    ("orchestrator/reports/routing_report.md", "orchestrator", "routing-report"),
    ("orchestrator/state/current_routing_state.json", "orchestrator", "routing-state"),
    ("goal-engine/goals/active_goals.md", "goals", "active-goals"),
    ("goal-engine/goals/completed_goals.md", "goals", "completed-goals"),
    ("goal-engine/planner/heuristics.md", "goals", "planning-heuristics"),
    ("goal-engine/planner/decomposition_policy.md", "goals", "decomposition-policy"),
    ("goal-engine/execution/execution_log.md", "goals", "execution-log"),
    ("goal-engine/state/goal_state.json", "goals", "goal-state"),
    ("goal-engine/state/current_goal.json", "goals", "current-goal"),
    ("goal-engine/reports/goal_report.md", "goals", "goal-report"),
    ("orchestrator/router/gstack_policy.json", "gstack", "gstack-policy"),
    ("agent-system/shared/AGENT_SYSTEM.md", "gstack", "gstack-skills-doc"),
]
total = 0
indexed = []
ts = now()
for rel, cat, label in sources:
    p = WORKSPACE / rel
    if not p.exists(): continue
    text = p.read_text(errors="replace")
    if p.suffix == ".md":
        parts = re.split(r"\n(#+\s+.+)", text)
        chunks = []
        sec = "_preamble"; buf = []
        for part in parts:
            if re.match(r"#+\s+", part.strip()):
                if buf: chunks.append((sec, "\n".join(buf)))
                sec = part.strip().lstrip("#").strip(); buf = []
            else: buf.append(part)
        if buf: chunks.append((sec, "\n".join(buf)))
        if not chunks: chunks = [("_all", text)]
        for s, body in chunks:
            body = body.strip()
            if len(body) < 10: continue
            tags = ",".join(re.findall(r"#\w+", body)[:10])
            conn.execute("INSERT INTO entries VALUES (NULL,?,?,?,?,?,?)",
                         (label, s, cat, tags, body[:4096], ts))
            total += 1
    else:
        conn.execute("INSERT INTO entries VALUES (NULL,?,?,?,?,?,?)",
                     (label, "_raw", cat, "", text.strip()[:4096], ts))
        total += 1
    indexed.append(label)

conn.commit()
conn.close()
meta = {"indexed_at": ts, "total_entries": total, "sources_indexed": indexed}
(SERVER / "state" / "last_index.json").write_text(json.dumps(meta, indent=2)+"\n")
# Update mcp_state.json
state_path = SERVER / "state" / "mcp_state.json"
try:
    state = json.loads(state_path.read_text()) if state_path.exists() else {}
    state["last_reindex"] = ts
    state["state_updated_at"] = ts
    state_path.write_text(json.dumps(state, indent=2)+"\n")
except Exception as e:
    print(f"Warning: could not update mcp_state.json: {e}")
print(f"Done: {total} entries from {len(indexed)} sources")
PY

# Run auto-discovery to surface any new unregistered files
python3 "${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}/mcp/server/scripts/auto_discover.py" --propose 2>/dev/null || true
