#!/bin/bash
cd ~/SuneelWorkSpace
source .venv/bin/activate 2>/dev/null || true
interval=${1:-45}
echo "🧬 Starting evolution engine (interval: ${interval}m)…"
exec python3 -c "
import sys
sys.path.insert(0, '.')
from evolution.engine import start_engine
start_engine(int(sys.argv[1]) if len(sys.argv) > 1 else 45)
" "$interval"
