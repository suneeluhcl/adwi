#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"
ensure_core_dirs

python3 - "$ROOT" "$INDEX_JSON" <<'PY'
import json, os, pathlib, sys
root = pathlib.Path(sys.argv[1])
out = pathlib.Path(sys.argv[2])
groups = {
    "shared": root / "agent-system" / "shared",
    "memory": root / "agent-system" / "memory",
    "tasks": root / "agent-system" / "tasks",
    "logs": root / "agent-system" / "logs",
    "state": root / "agent-system" / "state",
    "templates": root / "agent-system" / "templates",
    "docs": root / "agent-system" / "docs",
    "scripts": root / "bin",
    "automation": root / "automation",
}
def entry(path: pathlib.Path):
    try:
        stat = path.lstat()
    except FileNotFoundError:
        return None
    try:
        relative = str(path.relative_to(root))
    except ValueError:
        relative = None
    return {
        "path": str(path),
        "relative_path": relative,
        "type": "symlink" if path.is_symlink() else ("dir" if path.is_dir() else "file"),
        "target": os.readlink(path) if path.is_symlink() else None,
        "size": stat.st_size,
        "modified_epoch": int(stat.st_mtime),
    }
data = {
    "generated_at": __import__("datetime").datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z"),
    "workspace_root": str(root),
    "entrypoints": [e for p in [root/"AGENTS.md", root/"CLAUDE.md", pathlib.Path.home()/".codex/AGENTS.md", pathlib.Path.home()/".claude/CLAUDE.md"] if (e := entry(p))],
    "groups": {},
    "tools": {
        "codex": __import__("shutil").which("codex"),
        "claude": __import__("shutil").which("claude"),
    },
}
for name, directory in groups.items():
    items = []
    if directory.exists():
        for p in sorted(directory.rglob("*")):
            if p.is_file() or p.is_symlink():
                got = entry(p)
                if got:
                    items.append(got)
    data["groups"][name] = items
tmp = out.with_suffix(out.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
tmp.replace(out)
PY

# Call memory write hook on any memory/decision/pattern/insight/handoff files modified in the last 10 minutes
find "$ROOT" -type f -mmin -10 -not -path "*/.git/*" -not -path "*/.agent-backups/*" -not -path "*/vector/.hf_cache/*" -not -path "*/vector/chroma_store/*" 2>/dev/null | while read -r file; do
  "$ROOT/scripts/memory_write_hook.sh" "$file" >/dev/null 2>&1 || true
done

[ "${1:-}" = "--quiet" ] || echo "Updated $INDEX_JSON"
