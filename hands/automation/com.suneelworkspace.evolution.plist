<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.suneelworkspace.evolution</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd ~/SuneelWorkSpace &amp;&amp; source .venv/bin/activate &amp;&amp; bin/evolution-start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/tmp/suneelworkspace_evolution.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/suneelworkspace_evolution_error.log</string>
</dict>
</plist>
