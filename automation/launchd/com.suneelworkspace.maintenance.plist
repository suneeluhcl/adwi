<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.suneelworkspace.maintenance</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/MAC/SuneelWorkSpace/bin/agent-maintain</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>3600</integer>
  <key>StandardOutPath</key>
  <string>/Users/MAC/SuneelWorkSpace/automation/reports/launchd-maintenance.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/MAC/SuneelWorkSpace/automation/reports/launchd-maintenance.err.log</string>
  <key>WorkingDirectory</key>
  <string>/Users/MAC/SuneelWorkSpace</string>
</dict>
</plist>
