#!/bin/bash
# Start LocalAI for image generation (Stable Diffusion).
# First run downloads the model (~4GB) — subsequent starts are fast.

MODELS_DIR="$HOME/SuneelWorkSpace/localai-models"
LOG_FILE="$HOME/SuneelWorkSpace/notes/localai.log"

mkdir -p "$MODELS_DIR"

# Check if already running
if curl -s http://127.0.0.1:8080/v1/models >/dev/null 2>&1; then
    echo "LocalAI is already running on :8080"
    exit 0
fi

echo "Starting LocalAI on port 8080 (models: $MODELS_DIR)"
echo "First run will download Stable Diffusion (~4GB) — this is normal."
echo "Logs: $LOG_FILE"
echo ""

nohup local-ai \
    --models-path "$MODELS_DIR" \
    --address ":8080" \
    --log-level info \
    >> "$LOG_FILE" 2>&1 &

PID=$!
echo $PID > "$HOME/SuneelWorkSpace/localai-models/localai.pid"
echo "LocalAI started (PID $PID). Test with:"
echo "  curl http://127.0.0.1:8080/v1/models"
echo ""
echo "Then in adwi: /generate-image a sunset over mountains"
