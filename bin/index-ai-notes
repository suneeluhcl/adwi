#!/bin/zsh
set -e

NOTES_DIR="$HOME/SuneelWorkSpace/notes"
INDEX_FILE="$NOTES_DIR/AI-NOTES-INDEX.md"

mkdir -p "$NOTES_DIR"

{
  echo "# Suneel AI Notes Index"
  echo ""
  echo "Generated: $(date)"
  echo ""
  echo "Notes folder: \`$NOTES_DIR\`"
  echo ""
  echo "## Markdown and Text Notes"
  echo ""
  find "$NOTES_DIR" -type f \( -name "*.md" -o -name "*.txt" \) | sort | while read file; do
    rel="${file#$NOTES_DIR/}"
    title="$(head -n 1 "$file" 2>/dev/null | sed 's/^#* *//' | cut -c1-120)"
    if [ -z "$title" ]; then
      title="$rel"
    fi
    echo "- **$title**"
    echo "  - File: \`$rel\`"
  done
  echo ""
  echo "## Suggested Use"
  echo ""
  echo "- Use this index to understand what local AI memory files exist."
  echo "- Add important new summaries and reports into the notes folder."
  echo "- Re-run \`index-ai-notes\` after saving new notes."
} > "$INDEX_FILE"

echo "Created notes index:"
echo "$INDEX_FILE"
