#!/bin/bash
# Adwi nightly improvement launcher — called by com.suneel.adwi-nightly LaunchAgent at 2 AM

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export HOME="/Users/MAC"
WORKSPACE="$HOME/SuneelWorkSpace"

# Load secrets without printing them
if [ -f "$WORKSPACE/secrets/model-routing.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "$WORKSPACE/secrets/model-routing.env" 2>/dev/null || true
    set +a
fi

cd "$WORKSPACE"
exec python3 "$WORKSPACE/adwi/nightly.py"
