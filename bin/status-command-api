#!/bin/zsh
API_DIR="$HOME/SuneelWorkSpace/local-command-api"

echo "=== SAFE COMMAND API PROCESS ==="
if [ -f "$API_DIR/api.pid" ]; then
  ps -p "$(cat "$API_DIR/api.pid")" -o pid,stat,command || true
else
  echo "No PID file found."
fi

echo ""
echo "=== SAFE COMMAND API CHECK ==="
curl -s http://127.0.0.1:5055/ | python3 -m json.tool || echo "Safe Command API is not responding."

echo ""
echo "=== ALLOWED COMMAND TEST ==="
curl -s http://127.0.0.1:5055/status-ai | python3 -m json.tool | head -60 || true
