#!/bin/zsh
set +e

LOG_DIR="$HOME/SuneelWorkSpace/notes/self-heal-logs"
mkdir -p "$LOG_DIR"

STAMP="$(date +%Y%m%d-%H%M%S)"
LOG_FILE="$LOG_DIR/$STAMP-adwi-self-heal.md"

{
  echo "# Adwi Self-Heal Log"
  echo ""
  echo "Generated: $(date)"
  echo ""
  echo "Workspace: $HOME/SuneelWorkSpace"
  echo ""
  echo "## Safety Boundary"
  echo ""
  echo "This self-heal command only performs known safe repairs:"
  echo ""
  echo "- starts/checks Ollama"
  echo "- starts/checks Docker AI stack"
  echo "- starts/checks Safe Command API"
  echo "- refreshes notes index"
  echo "- creates daily status report"
  echo "- logs results"
  echo ""
  echo "It does NOT delete files, install unknown packages, access secrets, send email, change passwords, modify money-related accounts, or run arbitrary AI-generated commands."
  echo ""
  echo "## Step 1 - Ensure workspace folders exist"
  echo ""
  echo '```text'
  mkdir -p "$HOME/SuneelWorkSpace/bin" \
           "$HOME/SuneelWorkSpace/notes" \
           "$HOME/SuneelWorkSpace/notes/daily-status" \
           "$HOME/SuneelWorkSpace/notes/self-heal-logs" \
           "$HOME/SuneelWorkSpace/local-ai-stack" \
           "$HOME/SuneelWorkSpace/local-command-api"
  echo "Workspace folders verified."
  echo '```'
  echo ""
  echo "## Step 2 - Start Ollama"
  echo ""
  echo '```text'
  brew services start ollama
  sleep 3
  curl -s http://127.0.0.1:11434/api/tags || echo "Ollama API did not respond."
  echo '```'
  echo ""
  echo "## Step 3 - Start Docker AI stack"
  echo ""
  echo '```text'
  if [ -f "$HOME/SuneelWorkSpace/local-ai-stack/docker-compose.yml" ]; then
    cd "$HOME/SuneelWorkSpace/local-ai-stack"
    docker compose up -d
  else
    echo "docker-compose.yml not found. Skipping Docker stack start."
  fi
  echo '```'
  echo ""
  echo "## Step 4 - Start Safe Command API"
  echo ""
  echo '```text'
  if command -v start-command-api >/dev/null 2>&1; then
    start-command-api
  else
    echo "start-command-api command not found."
  fi
  echo '```'
  echo ""
  echo "## Step 5 - Refresh notes index"
  echo ""
  echo '```text'
  if command -v index-ai-notes >/dev/null 2>&1; then
    index-ai-notes
  else
    echo "index-ai-notes command not found."
  fi
  echo '```'
  echo ""
  echo "## Step 6 - Create daily status report"
  echo ""
  echo '```text'
  if command -v daily-ai-status-report >/dev/null 2>&1; then
    daily-ai-status-report
  else
    echo "daily-ai-status-report command not found."
  fi
  echo '```'
  echo ""
  echo "## Step 7 - Final status"
  echo ""
  echo '```text'
  if command -v status-ai >/dev/null 2>&1; then
    status-ai
  else
    echo "status-ai command not found."
  fi
  echo '```'
  echo ""
  echo "## Completed"
  echo ""
  echo "Completed: $(date)"
} | tee "$LOG_FILE"

echo ""
echo "=== ADWI SELF-HEAL COMPLETE ==="
echo "$LOG_FILE"
