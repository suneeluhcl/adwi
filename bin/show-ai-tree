#!/bin/zsh
set -e

ROOT="$HOME/SuneelWorkSpace"

echo "=== SUNEEL LOCAL AI WORKSPACE TREE ==="
echo "$ROOT"
echo ""

echo "Showing folder structure up to 3 levels deep."
echo "Skipping noisy internal data folders where practical."
echo ""

find "$ROOT" \
  -path "$ROOT/local-ai-stack/open-webui-data" -prune -o \
  -path "$ROOT/local-ai-stack/n8n-data" -prune -o \
  -path "$ROOT/local-ai-stack/searxng-data" -prune -o \
  -path "$ROOT/ollama/.ollama/models/blobs" -prune -o \
  -maxdepth 3 \
  -print | sed "s|$ROOT|SuneelWorkSpace|g" | sort

echo ""
echo "=== SUMMARY ==="
echo "Workspace root: $ROOT"
echo "Commands folder: $ROOT/bin"
echo "Notes folder: $ROOT/notes"
echo "Docker stack folder: $ROOT/local-ai-stack"
