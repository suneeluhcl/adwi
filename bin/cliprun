#!/bin/zsh
set +e
setopt NO_NOMATCH

if [ $# -eq 0 ]; then
  echo "Usage:"
  echo "  cliprun 'your command here'"
  echo "  cr 'your command here'"
  echo ""
  echo "Example:"
  echo "  cr 'status-ai'"
  exit 1
fi

CMD="$*"
STAMP="$(date '+%Y%m%d-%H%M%S')-$$-$RANDOM"
LOG_DIR="$HOME/SuneelWorkSpace/notes/clipboard-command-logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/$STAMP-command-output.md"
TMP_OUT="$(mktemp)"

echo "=== RUNNING COMMAND ==="
echo "$CMD"
echo ""

zsh -lc "$CMD" > "$TMP_OUT" 2>&1
STATUS=$?

cat "$TMP_OUT"
OUTPUT="$(cat "$TMP_OUT")"
rm -f "$TMP_OUT"

REDACTED_CMD="$(printf "%s" "$CMD" \
  | sed -E 's/sk-[A-Za-z0-9_-]{20,}/sk-REDACTED/g' \
  | sed -E 's/eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+/JWT-REDACTED/g' \
  | sed -E 's/(OPENWEBUI_API_KEY=).*/\1"REDACTED"/g' \
  | sed -E 's/(OPENWEBUI_JWT_TOKEN=).*/\1"REDACTED"/g' \
  | sed -E 's/(Authorization: Bearer )[A-Za-z0-9._-]+/\1REDACTED/g')"

REDACTED_OUTPUT="$(printf "%s" "$OUTPUT" \
  | sed -E 's/sk-[A-Za-z0-9_-]{20,}/sk-REDACTED/g' \
  | sed -E 's/eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+/JWT-REDACTED/g' \
  | sed -E 's/(OPENWEBUI_API_KEY=).*/\1"REDACTED"/g' \
  | sed -E 's/(OPENWEBUI_JWT_TOKEN=).*/\1"REDACTED"/g' \
  | sed -E 's/(Authorization: Bearer )[A-Za-z0-9._-]+/\1REDACTED/g')"

cat > "$LOG_FILE" <<LOG
# Command Output Clipboard Log

Generated: $(date)

Exit status: $STATUS

## Command

\`\`\`bash
$REDACTED_CMD
\`\`\`

## Output

\`\`\`text
$REDACTED_OUTPUT
\`\`\`
LOG

pbcopy < "$LOG_FILE"

echo ""
echo "=== COPIED TO CLIPBOARD ==="
echo "$LOG_FILE"
echo ""
echo "Exit status: $STATUS"

exit $STATUS
