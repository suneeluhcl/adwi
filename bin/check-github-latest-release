#!/bin/zsh
set -e

if [ -z "$1" ]; then
  echo "Usage: check-github-latest-release owner/repo"
  echo "Example: check-github-latest-release ollama/ollama"
  exit 1
fi

REPO="$1"

python3 - "$REPO" <<'PY'
import json
import sys
import urllib.request

repo = sys.argv[1]
url = f"https://api.github.com/repos/{repo}/releases/latest"

req = urllib.request.Request(
    url,
    headers={
        "Accept": "application/vnd.github+json",
        "User-Agent": "SuneelLocalAI"
    }
)

try:
    with urllib.request.urlopen(req, timeout=20) as response:
        data = json.load(response)
except Exception as e:
    print("ERROR: Could not fetch latest release.")
    print(str(e))
    sys.exit(1)

print("Repository:", repo)
print("Latest release tag:", data.get("tag_name", ""))
print("Release name:", data.get("name", ""))
print("Published at:", data.get("published_at", ""))
print("Release URL:", data.get("html_url", ""))
print()
print("Release notes preview:")
body = data.get("body") or ""
print(body[:1200] if body else "(No release notes found)")
PY
