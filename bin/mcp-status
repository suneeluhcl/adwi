#!/bin/bash
# Show status of all MCP servers and their backing services
echo "═══════════════════════════════════════════════"
echo "  Adwi MCP Server Status"
echo "═══════════════════════════════════════════════"

check() {
  local name="$1" port="$2"
  if nc -z 127.0.0.1 "$port" 2>/dev/null; then
    printf "  ✓ %-20s port %s\n" "$name" "$port"
  else
    printf "  ✗ %-20s port %s (offline)\n" "$name" "$port"
  fi
}

echo ""
echo "  Live services (need to be running):"
check "Qdrant"    6333
check "ComfyUI"   8188
check "Ollama"    11434
check "Safe API"  5055

echo ""
echo "  On-demand servers (npx/uvx — start automatically):"
for server in playwright fetch github sqlite memory sequential-thinking adwi-sandbox filesystem; do
  printf "  · %s\n" "$server"
done

echo ""
echo "  MCP config: ~/.config/mcp/servers.json"
echo "  Workspace DB: ~/SuneelWorkSpace/mcp-servers/workspace.db"
echo "═══════════════════════════════════════════════"

# Start Qdrant if not running
if ! nc -z 127.0.0.1 6333 2>/dev/null; then
  echo ""
  echo "  Starting Qdrant..."
  docker start suneel-qdrant 2>/dev/null || \
    docker run -d --name suneel-qdrant \
      -p 6333:6333 -p 6334:6334 \
      -v "$HOME/SuneelWorkSpace/mcp-servers/qdrant-data:/qdrant/storage:z" \
      qdrant/qdrant:latest
  sleep 2
  if nc -z 127.0.0.1 6333 2>/dev/null; then
    echo "  ✓ Qdrant started"
  else
    echo "  ✗ Qdrant failed to start"
  fi
fi
