#!/bin/bash
# Show git status for all repos in SuneelWorkSpace
WORKSPACE="$HOME/SuneelWorkSpace"
echo "=== Git Repos in $WORKSPACE ==="
echo ""
for dir in "$WORKSPACE"/*/; do
    if [ -d "$dir/.git" ]; then
        name=$(basename "$dir")
        branch=$(git -C "$dir" branch --show-current 2>/dev/null)
        status=$(git -C "$dir" status --short 2>/dev/null)
        ahead=$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo "0")
        echo "── $name [$branch] ahead=$ahead"
        if [ -n "$status" ]; then
            echo "$status" | head -10
        else
            echo "  (clean)"
        fi
        echo ""
    fi
done
