#!/bin/zsh
set -e

LOG_DIR="$HOME/SuneelWorkSpace/notes/maintenance-logs"
mkdir -p "$LOG_DIR"

STAMP="$(date +%Y%m%d-%H%M%S)"
LOG_FILE="$LOG_DIR/$STAMP-auto-ai-maintenance.md"

{
  echo "# Auto AI Maintenance Log"
  echo ""
  echo "Generated: $(date)"
  echo ""
  echo "Workspace: $HOME/SuneelWorkSpace"
  echo ""
  echo "## What this command does"
  echo ""
  echo "- Starts the local AI stack"
  echo "- Starts the Safe Command API"
  echo "- Creates a daily status report"
  echo "- Refreshes the notes index"
  echo "- Asks the local profile what to build next"
  echo ""
  echo "## Safety boundary"
  echo ""
  echo "This command does not delete files, install packages, upgrade software, send email, access credentials, or run arbitrary AI-generated commands."
  echo ""
  echo "## Step 1 - Start AI stack"
  echo ""
  echo '```text'
  start-ai
  echo '```'
  echo ""
  echo "## Step 2 - Start Safe Command API"
  echo ""
  echo '```text'
  if [ "$SUNEEL_COMMAND_API_CONTEXT" = "1" ]; then
    echo "Skipping start-command-api because auto-ai-maintenance is already running inside the Safe Command API."
  else
    start-command-api
  fi
  echo '```'
  echo ""
  echo "## Step 3 - Create daily status report"
  echo ""
  echo '```text'
  daily-ai-status-report
  echo '```'
  echo ""
  echo "## Step 4 - Refresh notes index"
  echo ""
  echo '```text'
  index-ai-notes
  echo '```'
  echo ""
  echo "## Step 5 - Current profile guidance"
  echo ""
  echo '```text'
  ask-ai-profile 'What is my current setup, what is already completed, and what should I build next?'
  echo '```'
  echo ""
  echo "## Maintenance completed"
  echo ""
  echo "Completed: $(date)"
} | tee "$LOG_FILE"

echo ""
echo "=== AUTO AI MAINTENANCE COMPLETE ==="
echo "$LOG_FILE"
