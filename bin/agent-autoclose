#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"

QUIET=0
FORCE=0
REASON="auto-closeout"
EXIT_CODE=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --quiet) QUIET=1 ;;
    --force) FORCE=1 ;;
    --reason) shift; REASON="${1:-auto-closeout}" ;;
    --exit-code) shift; EXIT_CODE="${1:-}" ;;
    --shell-exit) REASON="shell-exit" ;;
    --wrapper) shift; REASON="wrapper:${1:-agent}" ;;
    --startup-recovery) REASON="startup-recovery" ;;
    *) REASON="$1" ;;
  esac
  shift || true
done

ensure_core_dirs

# Keep health reasonably fresh without making every shell exit expensive.
if [ ! -f "$HEALTH_JSON" ] || [ -n "$(find "$HEALTH_JSON" -mmin +60 -print 2>/dev/null)" ]; then
  "$ROOT/bin/agent-doctor" --quiet >/dev/null 2>&1 || true
fi

python3 - "$ROOT" "$STATE_JSON" "$HEALTH_JSON" "$REASON" "$EXIT_CODE" "$FORCE" "$QUIET" <<'PY'
import hashlib
import json
import os
import pathlib
import subprocess
import sys
from datetime import datetime, timezone

root = pathlib.Path(sys.argv[1])
state_path = pathlib.Path(sys.argv[2])
health_path = pathlib.Path(sys.argv[3])
reason = sys.argv[4]
exit_code = sys.argv[5]
force = sys.argv[6] == "1"
quiet = sys.argv[7] == "1"

handoff_path = root / "agent-system/memory/SESSION_HANDOFF.md"
session_log = root / "agent-system/logs/SESSION_LOG.md"
active_tasks = root / "agent-system/tasks/ACTIVE_TASKS.md"
active_session_path = root / "agent-system/state/ACTIVE_SESSION.json"

def stamp():
    return datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z")

def date():
    return datetime.now().astimezone().strftime("%Y-%m-%d")

def load_json(path, default):
    try:
        return json.loads(path.read_text())
    except Exception:
        return dict(default)

def write_json(path, data):
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
    tmp.replace(path)

def run(cmd):
    try:
        return subprocess.run(cmd, cwd=root, text=True, capture_output=True, timeout=5)
    except Exception:
        return None

def git_changes():
    if not (root / ".git").exists():
        return []
    result = run(["git", "status", "--short"])
    if not result or result.returncode != 0:
        return []
    return [line for line in result.stdout.splitlines() if line.strip()][:30]

def recent_files():
    result = run(["find", str(root), "-type", "f", "-mtime", "-1", "-not", "-path", "*/.agent-backups/*", "-not", "-path", "*/.git/*"])
    if not result or result.returncode != 0:
        return []
    items = []
    for line in result.stdout.splitlines():
        p = pathlib.Path(line)
        try:
            items.append(str(p.relative_to(root)))
        except Exception:
            items.append(str(p))
    return sorted(items)[:30]

state = load_json(state_path, {})
health = load_json(health_path, {})
active_session = load_json(active_session_path, {}) if active_session_path.exists() else {}
now = stamp()

changes = git_changes()
if changes:
    change_text = "\n".join(f"- `{line}`" for line in changes)
    change_summary = f"{len(changes)} git status entries detected."
else:
    files = recent_files()
    change_text = "\n".join(f"- `{line}`" for line in files[:20]) if files else "- No recent file changes detected."
    change_summary = f"{len(files)} recently modified files detected." if files else "No recent file changes detected."

active = bool(state.get("active_session_detected") or active_session.get("active"))
session_id = state.get("active_session_id") or active_session.get("session_id")
fingerprint_src = "\n".join([str(session_id), reason, change_summary, "\n".join(changes[:20])])
fingerprint = hashlib.sha256(fingerprint_src.encode()).hexdigest()

if not force and not active and state.get("last_auto_closeout_fingerprint") == fingerprint:
    # Idempotent no-op: do not spam logs for repeated shell exits with no active session.
    state["last_activity_timestamp"] = now
    write_json(state_path, state)
    if not quiet:
        print("Auto-closeout skipped; no active session and no new checkpoint material.")
    raise SystemExit(0)

health_summary = f"{health.get('status', 'unknown')} ({health.get('issue_count', 0)} issues)"
exit_line = f"Exit code: {exit_code}" if exit_code else "Exit code: not recorded"
summary = f"Automatic closeout checkpoint ({reason}). {change_summary}"

handoff = f"""# Session Handoff

## Latest Handoff

Date: {date()}

Summary: {summary}

Changed:

{change_text}

Verification:

- Workspace health: {health_summary}
- {exit_line}
- Auto-closeout reason: `{reason}`

Open Items:

- Review `agent-system/tasks/ACTIVE_TASKS.md` and `agent-system/tasks/TASK_QUEUE.md`.
- Future agents should read `CURRENT_STATE.json` and this handoff before acting.
"""
handoff_path.write_text(handoff)

with session_log.open("a") as f:
    f.write(f"\n## {date()}\n\n")
    f.write(f"- {summary} Health: {health_summary}. {exit_line}.\n")

state.update({
    "active_session_detected": False,
    "active_session_id": None,
    "last_activity_timestamp": now,
    "last_auto_closeout_timestamp": now,
    "last_auto_closeout_reason": reason,
    "last_auto_closeout_fingerprint": fingerprint,
    "recent_task_summary": change_summary,
    "system_health_summary": health_summary,
    "state_updated_at": now,
    "last_summary": summary,
    "status": "auto-closed",
})
write_json(state_path, state)

active_session_path.parent.mkdir(parents=True, exist_ok=True)
write_json(active_session_path, {
    "active": False,
    "session_id": None,
    "closed_at": now,
    "closeout_reason": reason,
})

if not quiet:
    print(summary)
PY

"$ROOT/bin/workspace-index" --quiet >/dev/null 2>&1 || true
"$ROOT/bin/workspace-report" --quiet >/dev/null 2>&1 || true

[ "$QUIET" = "1" ] || echo "Auto-closeout complete."
