#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"
ensure_core_dirs

OUT="$ROOT/automation/reports/status-latest.md"
python3 - "$ROOT" "$STATE_JSON" "$HEALTH_JSON" "$OUT" <<'PY'
import json, pathlib, sys
from datetime import datetime
root, state_p, health_p, out_p = pathlib.Path(sys.argv[1]), pathlib.Path(sys.argv[2]), pathlib.Path(sys.argv[3]), pathlib.Path(sys.argv[4])
def load(p):
    try:
        return json.loads(p.read_text())
    except Exception as exc:
        return {"error": str(exc)}
state = load(state_p)
health = load(health_p)
handoff = (root / "agent-system/memory/SESSION_HANDOFF.md").read_text(errors="ignore").splitlines()[:28]
tasks = (root / "agent-system/tasks/ACTIVE_TASKS.md").read_text(errors="ignore").splitlines()[:28]
lines = [
    "# Workspace Status Report",
    "",
    f"Generated: {datetime.now().astimezone().strftime('%Y-%m-%dT%H:%M:%S%z')}",
    "",
    "## State",
    "",
    f"- Status: {state.get('status', 'unknown')}",
    f"- Last summary: {state.get('last_summary', 'unknown')}",
    f"- Updated: {state.get('state_updated_at', 'unknown')}",
    "",
    "## Health",
    "",
    f"- Status: {health.get('status', 'unknown')}",
    f"- Issue count: {health.get('issue_count', 'unknown')}",
]
for issue in health.get("issues", [])[:10]:
    lines.append(f"- {issue.get('severity', 'info')}: {issue.get('message', issue)}")
lines += ["", "## Recent Handoff", "", *handoff, "", "## Active Tasks", "", *tasks, ""]
out_p.write_text("\n".join(lines))
PY

[ "${1:-}" = "--quiet" ] || echo "Updated $OUT"
