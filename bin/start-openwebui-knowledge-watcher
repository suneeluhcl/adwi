#!/bin/zsh
set -e

WATCH_DIR="$HOME/SuneelWorkSpace/watchers/open-webui-knowledge"
mkdir -p "$WATCH_DIR"

if [ -f "$WATCH_DIR/watcher.pid" ] && ps -p "$(cat "$WATCH_DIR/watcher.pid")" >/dev/null 2>&1; then
  echo "Open WebUI Knowledge watcher is already running."
  echo "PID: $(cat "$WATCH_DIR/watcher.pid")"
  exit 0
fi

nohup "$HOME/SuneelWorkSpace/bin/watch-openwebui-knowledge" > "$WATCH_DIR/watcher.log" 2>&1 &
echo $! > "$WATCH_DIR/watcher.pid"
sleep 2

echo "Open WebUI Knowledge watcher started."
echo "PID: $(cat "$WATCH_DIR/watcher.pid")"
echo "Log: $WATCH_DIR/watcher.log"
tail -60 "$WATCH_DIR/watcher.log" || true
