{
  "id": null,
  "uid": "adwi-overview",
  "title": "Adwi Local AI — System Overview",
  "tags": ["adwi", "local-ai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Memories",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({job=\"adwi\", stream=\"system\"} |= \"memory\" [24h])",
          "legendFormat": "Memory ops"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Backup Commits (24h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({job=\"adwi\", stream=\"backup\"} |= \"SUCCESS\" [24h])",
          "legendFormat": "Successful backups"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Nightly Loop Status",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({job=\"adwi\", stream=\"nightly\"} |= \"ADWI NIGHTLY\" [24h])",
          "legendFormat": "Nightly runs"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "System CPU %",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "unit": "percent" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU used %"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Memory Used",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "unit": "bytes" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "RAM used"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Disk Used %",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":90}] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} * 100)",
          "legendFormat": "Disk %"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tool Response Latency (Adwi Traces)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "rate({job=\"adwi\",stream=\"trace\"} |= \"Running\" [5m])",
          "legendFormat": "Tool invocations/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Container Memory Footprint",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "container_memory_working_set_bytes{name=~\"suneel-.*\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Adwi System Log (live)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": { "dedupStrategy": "none", "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{job=\"adwi\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Backup Success / Failure Rate",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"adwi\",stream=\"backup\"} |= \"SUCCESS\" [1h]))",
          "legendFormat": "Successes/h"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"adwi\",stream=\"backup\"} |= \"FAILED\" [1h]))",
          "legendFormat": "Failures/h"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Nightly Loop Outcomes",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({job=\"adwi\",stream=\"nightly\"} |= \"syntax_ok\" [24h])",
          "legendFormat": "Syntax checks"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({job=\"adwi\",stream=\"nightly\"} |= \"aider\" [24h])",
          "legendFormat": "Aider invocations"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki"
      }
    ]
  }
}
